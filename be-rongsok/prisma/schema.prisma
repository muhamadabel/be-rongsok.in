generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

 datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [postgis]
 }

 // Enums
 enum Role {
   CUSTOMER
   COLLECTOR
   ADMIN
 }

 enum OrderStatus {
   PENDING
   CONFIRMED
   IN_PROGRESS
   AWAITING_CONFIRMATION
   COMPLETED
   CANCELLED
 }

 enum OrderMethod {
   PICKUP
   DROPOFF
 }

 // Models
 model User {
   id            String   @id @default(uuid())
   name          String
   email         String   @unique
   passwordHash  String
   phone         String?
   role          Role     @default(CUSTOMER)
   location      Unsupported("geography(Point, 4326)")?
   // Deskripsi alamat tertulis (jalan, patokan, dll) — pelengkap titik PostGIS
   addressText   String?
   avatarUrl     String?
   avgRating     Float    @default(0)
   // KYC (anti wash-trading: 1 KTP = 1 akun = 1 role)
   nik           String?  @unique
   ktpName       String?
   ktpUrl        String?
   isVerified    Boolean  @default(false)
   resetPasswordToken  String?
   resetPasswordExpires DateTime?
   createdAt     DateTime @default(now())
   collectorProfile CollectorProfile?
   orders        Order[]  @relation("CustomerOrders")
   // reverse relation for collector
   collectedOrders Order[] @relation("CollectorOrders")
   ratingsGiven  Rating[]  @relation("RaterRelation")
   ratingsReceived Rating[] @relation("RateeRelation")
   orderCollectors OrderCollector[]
 }

 model CollectorProfile {
   id          String   @id @default(uuid())
   user        User     @relation(fields: [userId], references: [id])
   userId      String   @unique
   shopName    String
   description String?
   shopImageUrl String?
   radiusKm    Float    @default(5)
   isOpen      Boolean  @default(true)
   // Jam buka lapak (teks bebas, mis. "Senin–Sabtu 08.00–17.00"). Hanya informatif —
   // buka/tutup tetap manual lewat isOpen, tidak otomatis ikut jam ini.
   operatingHours String?
   isPremium   Boolean  @default(false)
   priorityScore Int    @default(0)
   maxConcurrentOrders Int @default(5)
   catalogs    CollectorCatalog[]
 }

 model WasteCategory {
    id   String @id @default(uuid())
    name String @unique
    description String?
    iconUrl String?
    unit String @default("kg")        // satuan: kg | liter | pcs
    sortOrder Int @default(0)
    // Hierarki: parentId null = kategori utama (induk); terisi = sub-item
    parentId String?
    parent   WasteCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
    children WasteCategory[] @relation("CategoryHierarchy")
    collectorCatalogs CollectorCatalog[]
    orders            Order[]
    orderItems        OrderItem[]
  }

  model CollectorCatalog {
    id            String   @id @default(uuid())
    collector     CollectorProfile @relation(fields: [collectorId], references: [id])
    collectorId    String
    category      WasteCategory @relation(fields: [categoryId], references: [id])
    categoryId    String
    minPrice      Float
    maxPrice      Float
    isActive      Boolean @default(true)
  }

  model Order {
    id                String   @id @default(uuid())
    customer          User      @relation("CustomerOrders", fields: [customerId], references: [id])
    customerId        String
    collector         User?     @relation("CollectorOrders", fields: [collectorId], references: [id])
    collectorId       String?
    category          WasteCategory? @relation(fields: [categoryId], references: [id])
    categoryId        String?
    method            OrderMethod
    photoUrl          String?
    // Deskripsi alamat jemput/antar untuk order ini (disalin dari profil saat order dibuat)
    addressText       String?
    transactionProofUrl String?
    estimatedWeight   Float?
    actualWeight      Float?
    agreedPrice       Float?
    totalPrice        Float?
    status            OrderStatus @default(PENDING)
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt
    // map to collector candidates
    orderCollectors   OrderCollector[]
    ratings           Rating[]
    receipt           Receipt?
    items             OrderItem[]
  }

  model OrderItem {
    id              String        @id @default(uuid())
    order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
    orderId         String
    category        WasteCategory @relation(fields: [categoryId], references: [id])
    categoryId      String
    estimatedWeight Float
    actualWeight    Float?
    agreedPrice     Float?
    notes           String?
  }

 model OrderCollector {
   id          String @id @default(uuid())
   order       Order @relation(fields: [orderId], references: [id])
   orderId     String
   collector   User @relation(fields: [collectorId], references: [id])
   collectorId String
   status      String // notified, rejected, accepted
 }

 model Rating {
   id          String @id @default(uuid())
   order       Order @relation(fields: [orderId], references: [id])
   orderId     String
   rater       User @relation("RaterRelation", fields: [raterId], references: [id])
   raterId     String
   ratee       User @relation("RateeRelation", fields: [rateeId], references: [id])
   rateeId     String
   score       Int
   reviewText  String?
   photoUrl    String?
   createdAt   DateTime @default(now())
   @@unique([orderId, raterId])
 }

 model Receipt {
  id          String @id @default(uuid())
   order       Order @relation(fields: [orderId], references: [id])
   orderId     String @unique
   issuedAt    DateTime @default(now())
   detailsJson Json
 }

